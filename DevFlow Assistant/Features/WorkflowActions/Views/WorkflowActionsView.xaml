<UserControl x:Class="DevFlow_Assistant.Features.WorkflowActions.Views.WorkflowActionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Acciones del workflow" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Configura la secuencia que ejecutara este workflow." Style="{StaticResource HelpText}"/>
            </StackPanel>
            <Button Content="Volver al detalle" Command="{Binding BackCommand}" Style="{StaticResource SecondaryButton}" Width="150" DockPanel.Dock="Right"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Secuencia de acciones" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Selecciona una accion para editarla o usa Agregar para crear una nueva." Style="{StaticResource HelpText}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Actions}"
                              SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                              Visibility="{Binding Actions.Count, Converter={StaticResource HasItemsToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding SortOrder}" Width="50"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="1.2*"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding ActionType}" Width="120"/>
                            <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="1.6*"/>
                            <DataGridCheckBoxColumn Header="Activa" Binding="{Binding IsEnabled}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1"
                               Text="No hay acciones configuradas. Agrega una accion para abrir una app, URL, comando o servicio."
                               Style="{StaticResource EmptyStateText}"
                               Visibility="{Binding Actions.Count, Converter={StaticResource NoItemsToVisibilityConverter}}"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Subir" Command="{Binding MoveUpCommand}" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,8,0"/>
                        <Button Content="Bajar" Command="{Binding MoveDownCommand}" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,8,0"/>
                        <Button Content="Eliminar" Command="{Binding DeleteSelectedCommand}" Style="{StaticResource DangerButton}" Width="100"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Editor de accion" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Completa los campos principales. Los argumentos y directorio son opcionales segun el tipo de accion." Style="{StaticResource HelpText}" Margin="0,0,0,16"/>

                        <TextBlock Text="Nombre" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Ejemplo: Abrir VS Code"
                                 Style="{StaticResource TextInput}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Tipo" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding ActionTypes}"
                                  SelectedItem="{Binding SelectedActionType}"
                                  Height="38"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Valor principal" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="code, https://..., docker"
                                 Style="{StaticResource TextInput}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Argumentos" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="--version, up -d, ."
                                 Style="{StaticResource TextInput}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Directorio de trabajo" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="C:\ruta\del\proyecto"
                                 Style="{StaticResource TextInput}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Timeout en segundos" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="120"
                                 Style="{StaticResource TextInput}"
                                 Margin="0,0,0,12"/>

                        <CheckBox Content="Continuar con la siguiente accion si esta falla"
                                  IsChecked="{Binding ContinueOnError}"
                                  Margin="0,0,0,14"/>

                        <TextBlock Text="{Binding ValidationMessage}" Foreground="{StaticResource BrushDanger}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Agregar accion" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Width="130" Margin="0,0,8,0"/>
                            <Button Content="Guardar seleccion" Command="{Binding SaveSelectedCommand}" Style="{StaticResource SecondaryButton}" Width="150"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
