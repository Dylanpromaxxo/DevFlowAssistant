<UserControl x:Class="DevFlow_Assistant.Features.Workflows.Views.WorkflowCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Crear workflow" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Define una automatizacion que despues podra tener una o varias acciones." Style="{StaticResource HelpText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Nombre" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Ejemplo: Abrir entorno backend"
                         Style="{StaticResource TextInput}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Descripcion" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Ejemplo: Abre VS Code, Docker y paginas necesarias"
                         Style="{StaticResource TextInput}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="{Binding ValidationMessage}" Foreground="#DC2626" Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Guardar workflow" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="160" Margin="0,0,8,0"/>
                    <Button Content="Cancelar" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" Width="110"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
