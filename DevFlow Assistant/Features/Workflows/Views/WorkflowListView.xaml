<UserControl x:Class="DevFlow_Assistant.Features.Workflows.Views.WorkflowListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Workflows" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Crea, revisa y administra tus automatizaciones." Style="{StaticResource HelpText}"/>
            </StackPanel>
            <Button Content="Nuevo workflow"
                    Command="{Binding CreateCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Width="150"
                    DockPanel.Dock="Right"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,18">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Buscar por nombre o descripcion"
                     Style="{StaticResource TextInput}"/>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid ItemsSource="{Binding Workflows}"
                          SelectedItem="{Binding SelectedWorkflow, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="1.4*"/>
                        <DataGridTextColumn Header="Descripcion" Binding="{Binding Description}" Width="2*"/>
                        <DataGridCheckBoxColumn Header="Activo" Binding="{Binding IsActive}" Width="90"/>
                        <DataGridTextColumn Header="Creado" Binding="{Binding CreatedAt}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="Refrescar" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Width="110" Margin="0,0,8,0"/>
                    <Button Content="Ver detalle" Command="{Binding OpenDetailsCommand}" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,8,0"/>
                    <Button Content="Editar" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0"/>
                    <Button Content="Eliminar" Command="{Binding DeleteCommand}" Style="{StaticResource SecondaryButton}" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
