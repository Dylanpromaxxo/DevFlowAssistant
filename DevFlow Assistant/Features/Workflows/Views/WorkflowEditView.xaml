<UserControl x:Class="DevFlow_Assistant.Features.Workflows.Views.WorkflowEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Editar workflow" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Actualiza la informacion principal del workflow seleccionado." Style="{StaticResource HelpText}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Nombre" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Nombre visible del workflow"
                         Style="{StaticResource TextInput}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Descripcion" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Describe para que sirve este workflow"
                         Style="{StaticResource TextInput}"
                         Margin="0,0,0,12"/>

                <CheckBox Content="Workflow activo" IsChecked="{Binding IsActive}" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding ValidationMessage}" Foreground="#DC2626" Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Guardar cambios" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="150" Margin="0,0,8,0"/>
                    <Button Content="Cancelar" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" Width="110"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
