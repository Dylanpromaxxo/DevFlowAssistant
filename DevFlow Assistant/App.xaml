<Application x:Class="DevFlow_Assistant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dashboardViews="clr-namespace:DevFlow_Assistant.Features.Dashboard.Views"
             xmlns:dashboardVm="clr-namespace:DevFlow_Assistant.Features.Dashboard.ViewModels"
             xmlns:workflowViews="clr-namespace:DevFlow_Assistant.Features.Workflows.Views"
             xmlns:workflowVm="clr-namespace:DevFlow_Assistant.Features.Workflows.ViewModels"
             xmlns:actionViews="clr-namespace:DevFlow_Assistant.Features.WorkflowActions.Views"
             xmlns:actionVm="clr-namespace:DevFlow_Assistant.Features.WorkflowActions.ViewModels"
             xmlns:logViews="clr-namespace:DevFlow_Assistant.Features.ExecutionLogs.Views"
             xmlns:logVm="clr-namespace:DevFlow_Assistant.Features.ExecutionLogs.ViewModels">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type dashboardVm:DashboardViewModel}">
                <dashboardViews:DashboardView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type workflowVm:WorkflowListViewModel}">
                <workflowViews:WorkflowListView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type workflowVm:WorkflowCreateViewModel}">
                <workflowViews:WorkflowCreateView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type workflowVm:WorkflowEditViewModel}">
                <workflowViews:WorkflowEditView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type workflowVm:WorkflowDetailsViewModel}">
                <workflowViews:WorkflowDetailsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type actionVm:WorkflowActionsViewModel}">
                <actionViews:WorkflowActionsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type logVm:ExecutionLogsViewModel}">
                <logViews:ExecutionLogsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
